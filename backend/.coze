[project]
requires = ["python-3.12"]

[dev]
build = ["bash", "-c", "source venv/bin/activate && pip install fastapi uvicorn pydantic python-multipart"]
run = ["bash", "-c", "source venv/bin/activate && uvicorn main:app --reload --port 5000 --host 0.0.0.0"]

[deploy]
build = ["bash", "-c", "source venv/bin/activate && pip install -r requirements.txt"]
run = ["bash", "-c", "source venv/bin/activate && uvicorn main:app --port 5000 --host 0.0.0.0"]
