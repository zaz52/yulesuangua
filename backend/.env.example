# Copy this file to .env and put your own provider key in LLM_API_KEY.
# Do not commit .env.

# Recommended free setup for local development:
# NVIDIA NIM / NVIDIA Build. Requires your own NVIDIA API key from https://build.nvidia.com/.
LLM_API_KEY=
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.1-8b-instruct

# Alternative: OpenRouter free models router.
# LLM_API_KEY=
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openrouter/free

# Alternative: Google Gemini OpenAI-compatible endpoint.
# Requires your own Gemini API key from Google AI Studio.
# LLM_API_KEY=
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-3.5-flash
