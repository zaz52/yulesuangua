[project]
requires = ["nodejs-24"]

[dev]
build = ["bash", "-c", "cd frontend && pnpm install && pnpm build"]
run = ["bash", "-c", "cd backend && python3 -m uvicorn main:app --port 5000 --host 0.0.0.0"]

[deploy]
build = ["bash", "-c", "cd frontend && pnpm install && pnpm build"]
run = ["bash", "-c", "cd backend && python3 -m uvicorn main:app --port 5000 --host 0.0.0.0"]
